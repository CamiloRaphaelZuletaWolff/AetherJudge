# Arena backend environment — copy to .env (or run `task env:init`).
#
# This file is loaded automatically by `task gateway:run`, `task
# executor:run`, and `task db:seed`. It is NOT loaded for tests (test suites
# assert default-configuration behavior) or in CI (which uses defaults).
# Every value here matches the compiled-in default unless noted.

# ----- shared ---------------------------------------------------------------
APP_ENV=dev
LOG_LEVEL=info
# json in production; text is far easier to read in a terminal.
LOG_FORMAT=text

# ----- api-gateway ----------------------------------------------------------
GATEWAY_HTTP_ADDR=:8080
# Ports 55432/56379 match infra/docker/docker-compose.yml (non-standard on
# purpose: native PostgreSQL installs and WSL relays squat on 5432/6379).
DATABASE_URL=postgres://arena:arena_dev_password@localhost:55432/arena?sslmode=disable
REDIS_ADDR=localhost:56379
EXECUTOR_ADDR=localhost:9090

# Generate your own for .env:  task env:init  does this for you.
JWT_SECRET=replace-me-with-48-random-bytes-base64
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_HOURS=720

FRONTEND_ORIGIN=http://localhost:3000

# Consumer goroutines against the durable Redis judge queue. In a single
# local process this both serves HTTP and judges; in Kubernetes the web tier
# sets 0 and a separate worker deployment judges (ADR-0011).
JUDGE_WORKERS=2
# Reject new submissions (HTTP 503) once the stream holds this many.
JUDGE_QUEUE_DEPTH_LIMIT=1024
# Dead-letter a submission after this many failed delivery attempts.
JUDGE_MAX_DELIVERIES=5
# Consumer-group identity for this process (Kubernetes sets it to the pod name).
CONSUMER_NAME=gateway-local

# Production defaults are 10/6/10; local dev is friendlier so you can play
# without tripping limits.
RATE_LIMIT_AUTH_PER_MIN=30
RATE_LIMIT_SUBMIT_PER_MIN=30
RATE_LIMIT_RUN_PER_MIN=30

# ----- executor -------------------------------------------------------------
EXECUTOR_GRPC_ADDR=:9090
EXECUTOR_IMAGE_TAG=latest
EXECUTOR_MAX_CONCURRENT=2
EXECUTOR_RUN_TIMEOUT_MS=2000
EXECUTOR_RUN_TIMEOUT_MAX_MS=10000
EXECUTOR_RUN_MEMORY_MB=128
EXECUTOR_RUN_MEMORY_MAX_MB=512
EXECUTOR_COMPILE_TIMEOUT_MS=20000
EXECUTOR_COMPILE_MEMORY_MB=512
EXECUTOR_OUTPUT_LIMIT_KB=1024
# EXECUTOR_DOCKER_HOST=    # leave unset: named pipe on Windows, socket on Linux

# ----- observability (Phase 6) ----------------------------------------------
# Both services expose Prometheus metrics on dedicated internal listeners.
GATEWAY_METRICS_ADDR=:9100
EXECUTOR_METRICS_ADDR=:9101
# Tracing is OFF unless an OTLP endpoint is set. Run `task obs:up` (Tempo
# listens on 4317), uncomment, restart the services, and open Grafana at
# http://localhost:53000.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
