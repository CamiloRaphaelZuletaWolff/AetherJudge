# Copy to .env in this directory to override local infrastructure defaults.
# Every value has a working default in docker-compose.yml; this file exists
# so the defaults are documented and overridable without editing the compose file.

POSTGRES_USER=arena
POSTGRES_PASSWORD=arena_dev_password
POSTGRES_DB=arena
# Non-standard host ports on purpose: 5432/6379 are frequently occupied by
# native installs. The gateway's defaults match these.
POSTGRES_PORT=55432

REDIS_PORT=56379
