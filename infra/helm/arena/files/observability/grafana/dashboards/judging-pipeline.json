{
  "uid": "arena-judging",
  "title": "Arena — Judging Pipeline",
  "tags": ["arena"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Judge queue depth",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "arena_judge_queue_depth", "legendFormat": "queued" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Judged submissions by verdict",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (increase(arena_judge_jobs_total[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Judge latency p95 by language",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, language) (rate(arena_judge_duration_seconds_bucket[10m])))",
          "legendFormat": "{{language}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Sandbox phase p95 (where judge time goes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(arena_executor_phase_duration_seconds_bucket[10m])))",
          "legendFormat": "{{phase}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Executor executions by verdict",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (language, verdict) (increase(arena_executor_executions_total[5m]))",
          "legendFormat": "{{language}}/{{verdict}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Sandbox slots in use",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "arena_executor_active_executions", "legendFormat": "active" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Admission wait p95 (queueing before a slot)",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(arena_executor_admission_wait_seconds_bucket[10m])))",
          "legendFormat": "p95 wait"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "internal_error rate (should be zero)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(arena_judge_jobs_total{verdict=\"internal_error\"}[1h]))",
          "legendFormat": "internal errors (1h)"
        }
      ]
    }
  ]
}
